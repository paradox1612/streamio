DATABASE_URL=postgresql://postgres:password@localhost:5432/streambridge
PGSSLMODE=disable
TMDB_API_KEY=your_tmdb_api_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password
JWT_SECRET=your_super_secret_jwt_key_here
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_STARTUP_ENABLED=false
HEALTH_CHECK_BATCH_SIZE=2
HEALTH_CHECK_PROVIDER_MIN_INTERVAL_MS=3600000
ACCOUNT_LOOKUP_SUCCESS_TTL_SECONDS=600
ACCOUNT_LOOKUP_FAILURE_TTL_SECONDS=300

# ── Resend (email) ─────────────────────────────────────────────────────────────
# Used for transactional emails (password reset, etc.)
# Get your API key from https://resend.com → API Keys
# Domain must be verified in Resend dashboard (current domain: thekush.dev)
# GitHub secrets: RESEND_API_KEY, RESEND_FROM_EMAIL
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@thekush.dev

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Used to verify Google access tokens server-side via the userinfo endpoint.
# Get your client ID from https://console.cloud.google.com/ → APIs & Services → Credentials
# Only GOOGLE_CLIENT_ID is needed on the backend (no secret required for userinfo flow).
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PayGate.to ─────────────────────────────────────────────────────────────────
# Set PAYGATE_ENABLED=true and provide your USDC Polygon wallet address.
# API docs: https://documenter.getpostman.com/view/14826208/2sA3Bj9aBi
PAYGATE_ENABLED=false
PAYGATE_WALLET_ADDRESS=0xYourUSDCPolygonWalletAddress
# Public URL of this API server — used to build the PayGate callback URL.
# Must be reachable from the internet (not localhost) for callbacks to work.
API_BASE_URL=https://api.yoursite.com

# ── PIA VPN (Private Internet Access) ──────────────────────────────────────────
# Feature flag: set to "true" AND run docker compose with --profile vpn
VPN_ENABLED=false
# PIA credentials (also set as GitHub secrets PIA_USERNAME / PIA_PASSWORD)
PIA_USERNAME=your_pia_username
PIA_PASSWORD=your_pia_password
# Comma-separated PIA server regions for random selection on each rotation
PIA_SERVER_REGIONS=US East
# How often to rotate to a new PIA IP (hours, default: 6)
VPN_ROTATION_HOURS=1
# gluetun control API URL (no need to change for Docker; K8s uses localhost:8000)
GLUETUN_CONTROL_URL=http://gluetun:8000
